# ================================
# CopyPix — Variáveis de Ambiente
# ================================
# Copie este arquivo para .env e preencha os valores

# ——— TELEGRAM ———
CLIENT_BOT_TOKEN=       # Token do Bot dos Clientes (@BotFather)
ADMIN_BOT_TOKEN=        # Token do Bot Admin (@BotFather)
ADMIN_CHAT_ID=          # Seu Chat ID (use @userinfobot para descobrir)

# ——— PAGNET (R$ 100 – R$ 1.999) ———
PAGNET_PUBLIC_KEY=      # Chave pública da PagNet
PAGNET_SECRET_KEY=      # Chave secreta da PagNet
PAGNET_POSTBACK_URL=    # Ex: https://seudominio.com/webhook/pagnet

# ——— FLUXOPAY (R$ 5.001 – R$ 14.999) ———
FLUXOPAY_API_KEY=       # API Key da FluxoPay
FLUXOPAY_API_SECRET=    # API Secret da FluxoPay
# (configurar URL do webhook no painel da FluxoPay: /webhook/fluxopay)

# ——— PODPAY (R$ 5.001 – R$ 14.999) ———
PODPAY_API_KEY=         # API Key da PodPay
PODPAY_POSTBACK_URL=    # Ex: https://seudominio.com/webhook/podpay

# ——— PAINEL ADMIN ———
PANEL_PASSWORD=         # Senha para acessar /painel

# ——— SERVIDOR ———
PORT=3000
