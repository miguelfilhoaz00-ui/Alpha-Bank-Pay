# ================================
# Alpha Bank Pay — Variáveis de Ambiente
# ================================
# Copie este arquivo para .env e preencha os valores

# ——— TELEGRAM ———
CLIENT_BOT_TOKEN=       # Token do Bot dos Clientes (@BotFather)
ADMIN_BOT_TOKEN=        # Token do Bot Admin (@BotFather)
ADMIN_CHAT_ID=          # Seu Chat ID (use @userinfobot para descobrir)

# ——— SERVIDOR ———
APP_URL=                # Ex: https://alpha-bank-pay.onrender.com
PORT=3000

# ——— PAINEL ADMIN ———
PANEL_PASSWORD=         # Senha para acessar /painel

# ——— PODPAY (Depósitos) ———
PODPAY_API_KEY=
PODPAY_POSTBACK_URL=        # Ex: https://alpha-bank-pay.onrender.com/webhook/podpay

# ——— VEOPAG (Saques) ———
VEOPAG_CLIENT_ID=           # client_id emitido em dashboard.veopag.com/credentials
VEOPAG_CLIENT_SECRET=       # client_secret (mostrado uma única vez)
VEOPAG_WEBHOOK_URL=         # Ex: https://alpha-bank-pay.onrender.com/webhook/veopag
VEOPAG_WEBHOOK_SIGNATURE=   # Opcional: segredo estático do header X-Webhook-Signature

# ——— CLOUD BACKUP (OPCIONAL) ———
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
TELEGRAM_STORAGE_CHANNEL=
