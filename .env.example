# ================================
# Alpha Bank Pay — Variáveis de Ambiente
# ================================
# Copie este arquivo para .env e preencha os valores

# ——— TELEGRAM ———
CLIENT_BOT_TOKEN=       # Token do Bot dos Clientes (@BotFather)
ADMIN_BOT_TOKEN=        # Token do Bot Admin (@BotFather)
ADMIN_CHAT_ID=          # Seu Chat ID (use @userinfobot para descobrir)

# ——— SERVIDOR ———
APP_URL=                # Ex: https://alpha-bank-pay.onrender.com
PORT=3000

# ——— PAINEL ADMIN ———
PANEL_PASSWORD=         # Senha para acessar /painel

# ——— PAGNET (R$ 100 – R$ 1.999) ———
PAGNET_PUBLIC_KEY=
PAGNET_SECRET_KEY=
PAGNET_POSTBACK_URL=    # Ex: https://alpha-bank-pay.onrender.com/webhook/pagnet

# ——— SHARKBANKING (R$ 2.000 – R$ 4.000) ———
SHARKBANKING_PUBLIC_KEY=
SHARKBANKING_SECRET_KEY=
SHARKBANKING_POSTBACK_URL=  # Ex: https://alpha-bank-pay.onrender.com/webhook/sharkbanking

# ——— FLUXOPAY (R$ 5.001 – R$ 14.999) ———
FLUXOPAY_API_KEY=
FLUXOPAY_API_SECRET=
# (URL do webhook configurada no painel da FluxoPay: /webhook/fluxopay)

# ——— PODPAY (R$ 5.001 – R$ 14.999) ———
PODPAY_API_KEY=
PODPAY_POSTBACK_URL=    # Ex: https://alpha-bank-pay.onrender.com/webhook/podpay

# ——— XPAYTECH ———
XPAYTECH_USERNAME=      # Login da conta XPayTech
XPAYTECH_PASSWORD=      # Senha da conta XPayTech
XPAYTECH_WEBHOOK_URL=   # Ex: https://alpha-bank-pay.onrender.com/webhook/xpaytech

# ——— CLOUD BACKUP (OPCIONAL) ———
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
TELEGRAM_STORAGE_CHANNEL=
